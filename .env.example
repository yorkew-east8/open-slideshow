# open-slideshow 初始化配置（复制为 .env 后修改）
# 幻灯片库目录（宿主机路径：相对仓库根，或绝对路径）
# - 本地直跑：进程直接读这个路径
# - Docker/compose：compose 会把这个宿主机路径挂到容器内 /app/slides
#   例：SLIDES_DIR=/Users/you/Documents/my-slides
SLIDES_DIR=user-slides

# 首页端口
HOME_PORT=8080

# Slidev 播放器端口
SLIDEV_PORT=3030

# 默认主题（必须已在 apps/player/package.json 安装：default / seriph）
DEFAULT_THEME=default

# 历史列表最大条数
HISTORY_LIMIT=20
