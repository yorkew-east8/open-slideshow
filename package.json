{
  "name": "open-slideshow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/home",
    "apps/player",
    "server"
  ],
  "scripts": {
    "dev:home": "pnpm --filter home dev",
    "build:home": "pnpm --filter home build",
    "dev:player": "pnpm --filter player dev",
    "start:server": "pnpm --filter open-slideshow-server start",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "eslint-plugin-vue": "^9.28.0",
    "vue-eslint-parser": "^9.4.0",
    "prettier": "^3.3.0",
    "vitest": "^2.1.0",
    "jsdom": "^25.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
